{
    "name": "okay-vote",
    "version": "1.0.0",
    "private": true,
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "AGPL-3.0-only",
    "description": "https://okay.vote monorepo",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/okay-vote.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/okay-vote/issues"
    },
    "homepage": "https://github.com/Tenemo/okay-vote#readme",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=24 <25"
    },
    "scripts": {
        "prepare": "husky",
        "dev": "turbo run dev",
        "prebuild": "pnpm run tsc && pnpm run lint && pnpm run test && pnpm run build:workspaces",
        "build:workspaces": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "clean": "turbo run clean && pnpm exec rimraf .turbo test-results",
        "typecheck": "tsc --build --force",
        "tsc": "tsc --build --force",
        "e2e": "playwright test",
        "e2e:install": "playwright install --with-deps",
        "format": "prettier --write .",
        "db:migrate": "pnpm --filter @okay-vote/api db:migrate",
        "db:init": "pnpm --filter @okay-vote/api db:init",
        "docker:up": "docker compose up -d --wait && pnpm run db:migrate",
        "docker:destroy": "docker compose down -v",
        "docker:refresh": "pnpm run docker:destroy && pnpm run docker:up",
        "docker:reset": "pnpm run docker:refresh",
        "local:reset": "pnpm run docker:refresh"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-sql": "^3.4.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "turbo": "^2.9.4",
        "typescript": "^6.0.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "esbuild",
            "multiline-ts",
            "unrs-resolver"
        ]
    }
}
