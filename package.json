{
    "name": "okay-vote",
    "version": "1.0.0",
    "private": true,
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "UNLICENSED",
    "description": "okay-vote monorepo",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/okay-vote.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/okay-vote/issues"
    },
    "homepage": "https://github.com/Tenemo/okay-vote#readme",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=24 <25"
    },
    "scripts": {
        "prepare": "husky",
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "typecheck": "tsc --build",
        "tsc": "tsc --build",
        "format": "prettier --write .",
        "db:init": "pnpm --filter @okay-vote/api db:init",
        "docker:up": "docker compose up -d --wait && pnpm run db:init",
        "docker:destroy": "docker compose down -v",
        "docker:refresh": "pnpm run docker:destroy && pnpm run docker:up"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-babel-module": "^5.3.2",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-sql": "^3.4.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "turbo": "^2.9.3",
        "typescript": "^6.0.2"
    }
}
