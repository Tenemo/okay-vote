{
    "name": "okay-vote",
    "version": "1.0.0",
    "private": true,
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "UNLICENSED",
    "description": "okay-vote monorepo",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/okay-vote.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/okay-vote/issues"
    },
    "homepage": "https://github.com/Tenemo/okay-vote#readme",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=20 <21"
    },
    "scripts": {
        "prepare": "husky",
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "typecheck": "tsc --build",
        "tsc": "tsc --build",
        "format": "prettier --write .",
        "db:init": "pnpm --filter @okay-vote/api db:init",
        "docker:up": "docker compose up -d && pnpm run db:init",
        "docker:destroy": "docker compose down -v",
        "docker:refresh": "pnpm run docker:destroy && pnpm run docker:up"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^6.12.0",
        "@typescript-eslint/parser": "^6.12.0",
        "eslint": "^8.54.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^9.0.0",
        "eslint-import-resolver-babel-module": "^5.3.2",
        "eslint-import-resolver-typescript": "^3.6.1",
        "eslint-plugin-import": "^2.29.0",
        "eslint-plugin-jest": "^27.6.0",
        "eslint-plugin-jsx-a11y": "^6.8.0",
        "eslint-plugin-prettier": "^5.0.1",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "4.6.0",
        "eslint-plugin-sql": "^2.5.0",
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0",
        "prettier": "^3.1.0",
        "turbo": "^2.9.0",
        "typescript": "^5.4.0"
    }
}
