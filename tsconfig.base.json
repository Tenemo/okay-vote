{
    "compilerOptions": {
        "target": "ES2022",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    }
}
