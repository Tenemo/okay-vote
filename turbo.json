{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ],
            "outputLogs": "new-only"
        },
        "dev": {
            "dependsOn": [
                "^build"
            ],
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [],
            "outputLogs": "new-only"
        },
        "lint": {
            "outputs": [],
            "outputLogs": "new-only"
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ],
            "outputs": []
        },
        "clean": {
            "cache": false
        }
    }
}
