{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@okay-vote/contracts": ["../contracts/src/index.ts"]
        },
        "rootDir": "src",
        "outDir": "dist",
        "module": "esnext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "composite": true,
        "tsBuildInfoFile": "../../node_modules/.cache/tsconfig/packages-testkit.tsbuildinfo"
    },
    "include": ["src/**/*"],
    "references": [{ "path": "../contracts" }]
