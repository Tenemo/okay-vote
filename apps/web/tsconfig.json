{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": "./src",
        "jsx": "react",
        "module": "commonjs",
        "moduleResolution": "node",
        "removeComments": true,
        "allowJs": true,
        "noEmit": true,
        "composite": true,
        "tsBuildInfoFile": "../../node_modules/.cache/tsconfig/apps-web.tsbuildinfo",
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "include": ["src/**/*", "config/**/*"],
    "exclude": ["**/*.snap"],
    "references": [{ "path": "../../packages/contracts" }]
}
