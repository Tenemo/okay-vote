{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": "./src",
        "paths": {
            "@/*": ["./*"],
            "@okay-vote/contracts": ["../../../packages/contracts/src/index.ts"]
        },
        "jsx": "react-jsx",
        "module": "esnext",
        "moduleResolution": "bundler",
        "types": ["vite/client", "vitest/globals"],
        "removeComments": true,
        "allowJs": true,
        "noEmit": true,
        "composite": true,
        "tsBuildInfoFile": "../../node_modules/.cache/tsconfig/apps-web.tsbuildinfo",
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "include": [
        "src/**/*",
        "config/testSetup.ts",
        "vite.config.ts",
        "vitest.config.ts"
    ],
    "exclude": ["**/*.snap"],
    "references": [{ "path": "../../packages/contracts" }]
}
