{
    "name": "@okay-vote/web",
    "version": "1.0.0",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "AGPL-3.0-only",
    "type": "module",
    "description": "okay.vote web app",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/okay-vote.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/okay-vote/issues"
    },
    "homepage": "https://github.com/Tenemo/okay-vote#readme",
    "engines": {
        "node": ">=24 <25"
    },
    "scripts": {
        "start": "vite",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "eslint": "pnpm exec eslint src config/testSetup.ts vite.config.ts vitest.config.ts --ext ts,tsx",
        "eslint:fix": "pnpm exec eslint src config/testSetup.ts vite.config.ts vitest.config.ts --ext ts,tsx --fix",
        "stylelint": "stylelint **/*.scss **/*.css",
        "lint": "pnpm run eslint && pnpm run stylelint",
        "typecheck": "pnpm exec tsc --build --force tsconfig.json",
        "tsc": "pnpm exec tsc --build --force tsconfig.json",
        "test": "pnpm --filter @okay-vote/contracts build && vitest run --reporter verbose",
        "test:update": "pnpm run test -- --update",
        "test:coverage": "pnpm run test -- --coverage",
        "test:watch": "vitest"
    },
    "browserslist": [
        "> 0.5%",
        "not dead",
        "not IE > 0",
        "not op_mini all"
    ],
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.9",
        "@mui/material": "^7.3.9",
        "@reduxjs/toolkit": "^2.11.0",
        "@okay-vote/contracts": "workspace:*",
        "copy-to-clipboard": "^3.3.3",
        "normalize.css": "^8.0.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-helmet-async": "^3.0.0",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.14.0"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.4",
        "jsdom": "^29.0.1",
        "sass": "^1.99.0",
        "stylelint": "^17.6.0",
        "stylelint-config-recommended": "^18.0.0",
        "stylelint-config-recommended-scss": "^17.0.0",
        "stylelint-scss": "^7.0.0",
        "vite": "^7.1.5",
        "vitest": "^3.2.4"
    }
}
