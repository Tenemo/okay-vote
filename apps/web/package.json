{
    "name": "@okay-vote/web",
    "version": "1.0.0",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "UNLICENSED",
    "description": "okay-vote web app",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/okay-vote.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/okay-vote/issues"
    },
    "homepage": "https://github.com/Tenemo/okay-vote#readme",
    "engines": {
        "node": ">=20 <21"
    },
    "scripts": {
        "start": "pnpm run dev",
        "dev": "cross-env NODE_ENV=development PORT=3000 webpack serve --config config/webpack/webpack.dev.babel.ts",
        "build": "pnpm run cleanDist && cross-env NODE_ENV=production webpack --config config/webpack/webpack.prod.babel.ts",
        "build:analyze": "pnpm run cleanDist && cross-env NODE_ENV=production ANALYZE=true webpack --config config/webpack/webpack.prod.babel.ts",
        "build:skip": "pnpm run cleanDist && cross-env NODE_ENV=production webpack --config config/webpack/webpack.prod.babel.ts",
        "cleanDist": "rimraf ./dist && mkdir dist",
        "eslint": "pnpm exec eslint . --ext js,jsx,ts,tsx --ignore-pattern dist/**",
        "eslint:fix": "pnpm exec eslint . --ext js,jsx,ts,tsx --fix --ignore-pattern dist/**",
        "stylelint": "stylelint **/*.scss **/*.css",
        "lint": "pnpm run eslint && pnpm run stylelint",
        "open:dist": "http-server dist --port 4000 --proxy http://localhost:4000?",
        "open:src": "pnpm run dev",
        "typecheck": "pnpm exec tsc --build tsconfig.json",
        "tsc": "pnpm exec tsc --build tsconfig.json",
        "test": "pnpm --filter @okay-vote/contracts build && cross-env NODE_ENV=test jest --config jest.config.js --passWithNoTests",
        "test:update": "pnpm run test -- --update",
        "test:coverage": "pnpm run test -- --coverage",
        "test:watch": "pnpm run test -- --watch"
    },
    "browserslist": [
        "> 0.5%",
        "not dead",
        "not IE > 0",
        "not op_mini all"
    ],
    "dependencies": {
        "@babel/runtime-corejs3": "^7.23.4",
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@mui/icons-material": "^5.14.18",
        "@mui/material": "^5.14.18",
        "@okay-vote/contracts": "workspace:*",
        "axios": "^1.6.2",
        "copy-to-clipboard": "^3.3.3",
        "core-js": "^3.33.3",
        "history": "^5.3.0",
        "normalize.css": "^8.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-helmet-async": "^2.0.1",
        "react-redux": "^8.1.3",
        "react-router": "^6.20.0",
        "react-router-dom": "^6.20.0",
        "redux": "^4.2.1",
        "redux-persist": "^6.0.0",
        "redux-thunk": "^2.4.2",
        "reselect": "^4.1.8",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@babel/register": "^7.28.3",
        "@babel/core": "^7.23.3",
        "@babel/node": "^7.22.19",
        "@babel/plugin-proposal-class-properties": "^7.16.7",
        "@babel/preset-env": "^7.23.3",
        "@babel/preset-react": "^7.23.3",
        "@babel/preset-typescript": "^7.23.3",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
        "@teamsupercell/typings-for-css-modules-loader": "^2.5.2",
        "@testing-library/jest-dom": "^6.1.4",
        "@testing-library/react": "^14.1.2",
        "@types/circular-dependency-plugin": "^5.0.8",
        "@types/core-js": "^2.5.8",
        "@types/history": "^4.7.11",
        "@types/html-webpack-plugin": "^3.2.9",
        "@types/http-server": "^0.12.4",
        "@types/jest": "^29.5.10",
        "@types/jsdom": "^21.1.6",
        "@types/mini-css-extract-plugin": "^2.5.0",
        "@types/node": "^20.10.0",
        "@types/react": "^18.2.38",
        "@types/react-dom": "^18.2.17",
        "@types/react-redux": "^7.1.31",
        "@types/redux-logger": "^3.0.12",
        "@types/redux-mock-store": "^1.0.6",
        "@types/sass": "^1.43.1",
        "@types/uuid": "^9.0.7",
        "@types/webpack-bundle-analyzer": "^4.6.3",
        "@types/webpack-env": "^1.18.4",
        "autoprefixer": "^10.4.16",
        "babel-jest": "^29.7.0",
        "babel-loader": "^9.1.3",
        "babel-plugin-module-resolver": "^5.0.0",
        "circular-dependency-plugin": "^5.2.2",
        "copy-webpack-plugin": "^11.0.0",
        "cross-env": "^7.0.3",
        "css-loader": "^6.8.1",
        "css-minimizer-webpack-plugin": "^5.0.1",
        "html-webpack-plugin": "^5.5.3",
        "http-server": "^14.1.1",
        "immutable": "^4.3.4",
        "jest": "^29.7.0",
        "jest-cli": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jsdom": "^22.1.0",
        "mini-css-extract-plugin": "^2.7.6",
        "postcss": "^8.4.31",
        "postcss-flexbugs-fixes": "^5.0.2",
        "postcss-html": "^1.5.0",
        "postcss-loader": "^7.3.3",
        "react-refresh": "^0.14.0",
        "redux-devtools-extension": "^2.13.9",
        "redux-logger": "^3.0.6",
        "redux-mock-store": "^1.5.4",
        "rimraf": "^5.0.5",
        "sass": "^1.69.5",
        "sass-loader": "^13.3.2",
        "style-loader": "^3.3.3",
        "stylelint": "^15.11.0",
        "stylelint-config-recommended": "^13.0.0",
        "stylelint-config-recommended-scss": "^13.1.0",
        "stylelint-scss": "^5.3.1",
        "webpack": "^5.89.0",
        "webpack-bundle-analyzer": "^4.10.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.1",
        "webpack-merge": "^5.10.0"
    }
}
