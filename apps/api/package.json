{
    "name": "@okay-vote/api",
    "version": "1.0.0",
    "description": "okay-vote api",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/okay-vote.git"
    },
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "AGPL-3.0-only",
    "bugs": {
        "url": "https://github.com/Tenemo/okay-vote/issues"
    },
    "homepage": "https://github.com/Tenemo/okay-vote#readme",
    "engines": {
        "node": ">=24 <25"
    },
    "scripts": {
        "start": "node dist/server.js",
        "dev": "pnpm run db:migrate && pnpm --filter @okay-vote/contracts build && ts-node --transpile-only src/server.ts",
        "build": "pnpm --filter @okay-vote/contracts build && pnpm run cleanDist && cross-env NODE_ENV=production babel --extensions \".ts\" src --out-dir dist",
        "build:skip": "pnpm run build",
        "db:init": "pnpm run db:migrate",
        "db:migrate": "ts-node --transpile-only src/scripts/migrate-db.ts",
        "db:generate": "drizzle-kit generate --config drizzle.config.ts",
        "cleanDist": "rimraf ./dist && mkdir dist",
        "nodemon": "nodemon",
        "lint": "pnpm exec eslint . --ext js,ts --ignore-pattern dist/**",
        "lint:fix": "pnpm exec eslint . --ext js,ts --fix --ignore-pattern dist/**",
        "typecheck": "pnpm exec tsc --build tsconfig.json",
        "tsc": "pnpm exec tsc --build tsconfig.json",
        "test": "pnpm --filter @okay-vote/contracts build && vitest run --reporter verbose",
        "test:coverage": "pnpm run test -- --coverage",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@okay-vote/contracts": "workspace:*",
        "dotenv": "^17.4.0",
        "drizzle-orm": "^0.44.7",
        "fastify": "^5.8.4",
        "gmean": "^1.0.7",
        "http-errors": "^2.0.1",
        "pg": "^8.16.3",
        "pino-pretty": "^13.1.3"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/node": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-typescript": "^7.28.5",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.2",
        "@types/pg": "^8.20.0",
        "babel-jest": "^30.3.0",
        "babel-plugin-module-resolver": "^5.0.3",
        "core-js": "^3.49.0",
        "cross-env": "^10.1.0",
        "drizzle-kit": "^0.31.5",
        "nodemon": "^3.1.14",
        "rimraf": "^6.1.3",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "vite": "^7.1.5",
        "vitest": "^3.2.4"
    }
}
