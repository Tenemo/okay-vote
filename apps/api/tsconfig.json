{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": "./src",
        "module": "commonjs",
        "removeComments": true,
        "allowJs": true,
        "noEmit": true,
        "composite": true,
        "tsBuildInfoFile": "../../node_modules/.cache/tsconfig/apps-api.tsbuildinfo",
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "ts-node": {
        "require": ["tsconfig-paths/register"]
    },
    "include": ["src/**/*", "test/**/*"],
    "references": [{ "path": "../../packages/contracts" }]
}
