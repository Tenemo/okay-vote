{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": "./src",
        "paths": {
            "@okay-vote/contracts": ["../../../packages/contracts/src/index.ts"]
        },
        "rootDir": ".",
        "module": "commonjs",
        "removeComments": true,
        "allowJs": true,
        "noEmit": true,
        "composite": true,
        "tsBuildInfoFile": "../../node_modules/.cache/tsconfig/apps-api.tsbuildinfo",
        "types": ["node", "vitest/globals"],
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "ts-node": {
        "require": ["tsconfig-paths/register"]
    },
    "include": [
        "src/**/*",
        "test/**/*",
        "drizzle.config.ts",
        "vitest.config.ts"
    ],
    "references": [{ "path": "../../packages/contracts" }]
}
